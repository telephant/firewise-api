{
  "name": "firewise-api",
  "version": "1.0.0",
  "description": "Firewise expense tracking API",
  "main": "dist/index.js",
  "scripts": {
    "dev": "ts-node-dev --respawn --transpile-only src/index.ts",
    "build": "tsc",
    "start": "node dist/index.js",
    "test": "jest",
    "test:watch": "jest --watch ",
    "test:connection": "jest --testMatch='**/supabase.connection.test.ts' --setupFiles='' --verbose",
    "task": "ts-node tasks/index.ts",
    "task:help": "echo \"\nScheduled:\\n  npm run task:daily       — update-currency, process-dca, dividend-sync, savings-interest\\n  npm run task:weekly      — price-cache-cleanup\\n  npm run task:monthly     — portfolio-snapshot\\n\\nIndividual:\\n  npm run task:update-currency\\n  npm run task:dca\\n  npm run task:dividend-sync\\n  npm run task:savings-interest\\n  npm run task:price-cleanup\\n  npm run task:portfolio-snapshot  [-- --month=YYYY-MM]\\n\"",
    "task:daily": "ts-node tasks/index.ts run-daily",
    "task:weekly": "ts-node tasks/index.ts run-weekly",
    "task:monthly": "ts-node tasks/index.ts run-monthly",
    "task:update-currency": "ts-node tasks/index.ts update-currency",
    "task:dca": "ts-node tasks/index.ts process-dca",
    "task:dividend-sync": "ts-node tasks/index.ts dividend-sync",
    "task:savings-interest": "ts-node tasks/index.ts savings-interest",
    "task:price-cleanup": "ts-node tasks/index.ts price-cache-cleanup",
    "task:portfolio-snapshot": "ts-node tasks/index.ts portfolio-snapshot"
  },
  "keywords": [],
  "author": "",
  "license": "ISC",
  "engines": {
    "node": ">=20"
  },
  "dependencies": {
    "@supabase/supabase-js": "^2.88.0",
    "cors": "^2.8.5",
    "dotenv": "^17.2.3",
    "express": "^5.2.1",
    "helmet": "^8.1.0",
    "resend": "^6.9.1"
  },
  "devDependencies": {
    "@types/cors": "^2.8.19",
    "@types/express": "^5.0.6",
    "@types/jest": "^30.0.0",
    "@types/node": "^25.0.3",
    "@types/supertest": "^6.0.3",
    "jest": "^30.2.0",
    "supertest": "^7.1.4",
    "ts-jest": "^29.4.6",
    "ts-node": "^10.9.2",
    "ts-node-dev": "^2.0.0",
    "typescript": "^5.9.3"
  }
}
